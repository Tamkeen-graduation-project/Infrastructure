# Database
DATABASE_PASSWORD=your_db_password
DATABASE_TEST_PASSWORD=your_test_db_password

# Service Image Versions
BACKEND_VERSION=latest
FRONTEND_VERSION=latest
AI_TRACKER_VERSION=latest
AI_RECOMMENDATION_VERSION=latest
AI_CHATBOT_VERSION=latest

# App Secrets (used by test container)
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
ACCESS_TOKEN_LIFETIME=15m
REFRESH_TOKEN_LIFETIME=7d
APP_PASSWORD=your_app_password
ENCRYPTION_KEY=your_encryption_key
NODE_ENV=production
API_PREFIX=/api/v1
CLIENT_URL=https://tamkeeneg.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://tamkeeneg.com/api/v1/auth/google/callback
ADMIN_PASSWORD=your_admin_password
ADMIN_EMAIL=admin@tamkeen.com
TRACKING_API_KEY=your_tracking_api_key
AI_WEBHOOK_SECRET=your_ai_webhook_secret
RECOMMENDATION_API_KEY=your_recommendation_api_key
RECOMMENDATION_API_URL_DEV=http://localhost:8001
RECOMMENDATION_API_URL_PROD=http://tamkeen-recommendation-api:8001
SECURITY_API_KEY=your_security_api_key

# Nginx / SSL
CERTBOT_EMAIL=your_email@gmail.com
